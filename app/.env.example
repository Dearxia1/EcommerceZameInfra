PORT=3000
JWT_SECRET=super-secret-key-zame

# Database Configuration (MySQL / AWS RDS)
# If DB_HOST is omitted, Sequelize will automatically fall back to local SQLite database.
DB_HOST=
DB_PORT=3306
DB_NAME=zame_db
DB_USER=admin
DB_PASS=password123

# ePayco payment gateway
# In local development, EPAYCO_MOCK=true approves payments without contacting ePayco.
# Set EPAYCO_MOCK=false and fill the keys to use ePayco test mode.
EPAYCO_MOCK=true
EPAYCO_TEST_MODE=true
EPAYCO_PUBLIC_KEY=
EPAYCO_PRIVATE_KEY=
EPAYCO_TEST_PRICE_DIVISOR=10
EPAYCO_TEST_MAX_AMOUNT=200000
EPAYCO_RESPONSE_URL=http://localhost:3000/checkout.html
EPAYCO_CONFIRMATION_URL=http://localhost:3000/api/payments/epayco/confirmation
